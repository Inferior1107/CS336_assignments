        \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{token\PYGZus{}to\PYGZus{}id} \PYG{o}{=} \PYG{p}{\PYGZob{}}\PYG{n}{v}\PYG{p}{:} \PYG{n}{k} \PYG{k}{for} \PYG{n}{k}\PYG{p}{,} \PYG{n}{v} \PYG{o+ow}{in} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{vocab}\PYG{o}{.}\PYG{n}{items}\PYG{p}{()\PYGZcb{}}
        
