        \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{special\PYGZus{}tokens} \PYG{o}{=} \PYG{n}{special\PYGZus{}tokens} \PYG{o+ow}{or} \PYG{p}{[]}
        
