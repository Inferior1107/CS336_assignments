        \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{merge\PYGZus{}ranks} \PYG{o}{=} \PYG{p}{\PYGZob{}}\PYG{n}{pair}\PYG{p}{:} \PYG{n}{i} \PYG{k}{for} \PYG{n}{i}\PYG{p}{,} \PYG{n}{pair} \PYG{o+ow}{in} \PYG{n+nb}{enumerate}\PYG{p}{(}\PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{merges}\PYG{p}{)\PYGZcb{}}
        
