        \PYG{k}{for} \PYG{n}{st} \PYG{o+ow}{in} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{special\PYGZus{}tokens}\PYG{p}{:}
            \PYG{n}{st\PYGZus{}bytes} \PYG{o}{=} \PYG{n}{st}\PYG{o}{.}\PYG{n}{encode}\PYG{p}{(}\PYG{l+s+s2}{\PYGZdq{}utf\PYGZhy{}8\PYGZdq{}}\PYG{p}{)}
            \PYG{k}{if} \PYG{n}{st\PYGZus{}bytes} \PYG{o+ow}{not} \PYG{o+ow}{in} \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{token\PYGZus{}to\PYGZus{}id}\PYG{p}{:}
                \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{vocab}\PYG{p}{[}\PYG{n}{next\PYGZus{}id}\PYG{p}{]} \PYG{o}{=} \PYG{n}{st\PYGZus{}bytes}
                \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{token\PYGZus{}to\PYGZus{}id}\PYG{p}{[}\PYG{n}{st\PYGZus{}bytes}\PYG{p}{]} \PYG{o}{=} \PYG{n}{next\PYGZus{}id}
                \PYG{n}{next\PYGZus{}id} \PYG{o}{+=} \PYG{l+m+mi}{1}

        \PYG{c+c1}{\PYGZsh{} 编译用于切分特殊 Token 的正则表达式}
        \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{st\PYGZus{}pattern} \PYG{o}{=} \PYG{k+kc}{None}
