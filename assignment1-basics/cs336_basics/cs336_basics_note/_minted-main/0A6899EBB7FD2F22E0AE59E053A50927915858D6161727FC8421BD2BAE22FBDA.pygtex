\PYG{l+s+sd}{        初始化 Tokenizer，建立查找索引并处理特殊 Token。}
\PYG{l+s+sd}{        \PYGZdq{}\PYGZdq{}\PYGZdq{}}
        \PYG{n+nb+bp}{self}\PYG{o}{.}\PYG{n}{vocab} \PYG{o}{=} \PYG{n}{vocab}\PYG{o}{.}\PYG{n}{copy}\PYG{p}{()}
