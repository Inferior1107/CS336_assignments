    \PYG{n}{theta}\PYG{p}{:} \PYG{n+nb}{float}\PYG{p}{,}
    \PYG{n}{weights}\PYG{p}{:} \PYG{n+nb}{dict}\PYG{p}{[}\PYG{n+nb}{str}\PYG{p}{,} \PYG{n}{Tensor}\PYG{p}{],}
