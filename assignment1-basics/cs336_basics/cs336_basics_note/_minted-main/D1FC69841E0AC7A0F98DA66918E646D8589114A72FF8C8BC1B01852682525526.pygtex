\PYG{p}{)} \PYG{o}{\PYGZhy{}\PYGZgt{}} \PYG{n}{Float}\PYG{p}{[}\PYG{n}{Tensor}\PYG{p}{,} \PYG{l+s+s2}{\PYGZdq{} batch sequence\PYGZus{}length d\PYGZus{}model\PYGZdq{}}\PYG{p}{]:}
\PYG{+w}{    }\PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}
\PYG{l+s+sd}{    Given the weights of a pre\PYGZhy{}norm Transformer block and input features,}
\PYG{l+s+sd}{    return the output of running the Transformer block on the input features.}

\PYG{l+s+sd}{    This function should use RoPE.}
\PYG{l+s+sd}{    Depending on your implementation, you may simply need to pass the relevant args}
\PYG{l+s+sd}{    to your TransformerBlock constructor, or you may need to initialize your own RoPE}
\PYG{l+s+sd}{    class and pass that instead.}

\PYG{l+s+sd}{    Args:}
\PYG{l+s+sd}{        d\PYGZus{}model (int): The dimensionality of the Transformer block input.}
\PYG{l+s+sd}{        num\PYGZus{}heads (int): Number of heads to use in multi\PYGZhy{}headed attention. `d\PYGZus{}model` must be}
\PYG{l+s+sd}{            evenly divisible by `num\PYGZus{}heads`.}
\PYG{l+s+sd}{        d\PYGZus{}ff (int): Dimensionality of the feed\PYGZhy{}forward inner layer.}
\PYG{l+s+sd}{        max\PYGZus{}seq\PYGZus{}len (int): Maximum sequence length to pre\PYGZhy{}cache if your implementation does that.}
\PYG{l+s+sd}{        theta (float): RoPE parameter.}
\PYG{l+s+sd}{        weights (dict[str, Tensor]):}
\PYG{l+s+sd}{            State dict of our reference implementation.}
\PYG{l+s+sd}{            The keys of this dictionary are:}
\PYG{l+s+sd}{            \PYGZhy{} `attn.q\PYGZus{}proj.weight`}
\PYG{l+s+sd}{                The query projections for all `num\PYGZus{}heads` attention heads.}
\PYG{l+s+sd}{                Shape is (d\PYGZus{}model, d\PYGZus{}model).}
\PYG{l+s+sd}{                The rows are ordered by matrices of shape (num\PYGZus{}heads, d\PYGZus{}k),}
\PYG{l+s+sd}{                so `attn.q\PYGZus{}proj.weight == torch.cat([q\PYGZus{}heads.0.weight, ..., q\PYGZus{}heads.N.weight], dim=0)`.}
\PYG{l+s+sd}{            \PYGZhy{} `attn.k\PYGZus{}proj.weight`}
\PYG{l+s+sd}{                The key projections for all `num\PYGZus{}heads` attention heads.}
\PYG{l+s+sd}{                Shape is (d\PYGZus{}model, d\PYGZus{}model).}
\PYG{l+s+sd}{                The rows are ordered by matrices of shape (num\PYGZus{}heads, d\PYGZus{}k),}
\PYG{l+s+sd}{                so `attn.k\PYGZus{}proj.weight == torch.cat([k\PYGZus{}heads.0.weight, ..., k\PYGZus{}heads.N.weight], dim=0)`.}
\PYG{l+s+sd}{            \PYGZhy{} `attn.v\PYGZus{}proj.weight`}
\PYG{l+s+sd}{                The value projections for all `num\PYGZus{}heads` attention heads.}
\PYG{l+s+sd}{                Shape is (d\PYGZus{}model, d\PYGZus{}model).}
\PYG{l+s+sd}{                The rows are ordered by matrices of shape (num\PYGZus{}heads, d\PYGZus{}v),}
\PYG{l+s+sd}{                so `attn.v\PYGZus{}proj.weight == torch.cat([v\PYGZus{}heads.0.weight, ..., v\PYGZus{}heads.N.weight], dim=0)`.}
\PYG{l+s+sd}{            \PYGZhy{} `attn.output\PYGZus{}proj.weight`}
\PYG{l+s+sd}{                Weight of the multi\PYGZhy{}head self\PYGZhy{}attention output projection}
\PYG{l+s+sd}{                Shape is (d\PYGZus{}model, d\PYGZus{}model).}
\PYG{l+s+sd}{            \PYGZhy{} `ln1.weight`}
\PYG{l+s+sd}{                Weights of affine transform for the first RMSNorm}
\PYG{l+s+sd}{                applied in the transformer block.}
\PYG{l+s+sd}{                Shape is (d\PYGZus{}model,).}
\PYG{l+s+sd}{            \PYGZhy{} `ffn.w1.weight`}
\PYG{l+s+sd}{                Weight of the first linear transformation in the FFN.}
\PYG{l+s+sd}{                Shape is (d\PYGZus{}model, d\PYGZus{}ff).}
\PYG{l+s+sd}{            \PYGZhy{} `ffn.w2.weight`}
\PYG{l+s+sd}{                Weight of the second linear transformation in the FFN.}
\PYG{l+s+sd}{                Shape is (d\PYGZus{}ff, d\PYGZus{}model).}
\PYG{l+s+sd}{            \PYGZhy{} `ffn.w3.weight`}
\PYG{l+s+sd}{                Weight of the third linear transformation in the FFN.}
\PYG{l+s+sd}{                Shape is (d\PYGZus{}model, d\PYGZus{}ff).}
\PYG{l+s+sd}{            \PYGZhy{} `ln2.weight`}
\PYG{l+s+sd}{                Weights of affine transform for the second RMSNorm}
\PYG{l+s+sd}{                applied in the transformer block.}
\PYG{l+s+sd}{                Shape is (d\PYGZus{}model,).}
\PYG{l+s+sd}{        in\PYGZus{}features (Float[Tensor, \PYGZdq{}batch sequence\PYGZus{}length d\PYGZus{}model\PYGZdq{}]):}
\PYG{l+s+sd}{            Tensor to run your implementation on.}

\PYG{l+s+sd}{    Returns:}
\PYG{l+s+sd}{        Float[Tensor, \PYGZdq{}batch sequence\PYGZus{}length d\PYGZus{}model\PYGZdq{}] Tensor with the output of}
\PYG{l+s+sd}{        running the Transformer block on the input features while using RoPE.}
