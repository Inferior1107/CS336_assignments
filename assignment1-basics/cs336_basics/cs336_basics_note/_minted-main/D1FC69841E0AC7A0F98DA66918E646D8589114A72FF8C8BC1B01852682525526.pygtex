\PYG{l+s+sd}{                Shape is (d\PYGZus{}model,).}
\PYG{l+s+sd}{            \PYGZhy{} `ln\PYGZus{}final.weight`}
\PYG{l+s+sd}{                Weights of affine transform for RMSNorm applied to the output of the final transformer block.}
\PYG{l+s+sd}{                Shape is (d\PYGZus{}model, ).}
